# Models & Large Data
# Ignore heavy model checkpoints
models/*.pth
# Ignore video source files
src/videos/*.mp4
src/videos/*.f400.mp4
src/videos/*.txt

# Dataset
# We ignore high-level dataset folders but specifically ALLOW the uncleaned images as requested
# First, ignore everything in dataset to be safe
dataset/
# Then allow the uncleaned folder
!src/dataset/uncleaned/
!src/dataset/uncleaned/*.png
!src/dataset/uncleaned/*.csv

# Overlays (Inference results)
overlays/
models/evaluation/

# Electron / Frontend
enemy-detection-app/node_modules/
enemy-detection-app/dist/
enemy-detection-app/.eslintcache
enemy-detection-app/package-lock.json

# System
.DS_Store
Thumbs.db
